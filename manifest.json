{
  "manifest_version": 3,
  "name": "Page Crawler",
  "version": "0.6.0",
  "description": "Crawl a website, review it in NotebookLM, one click.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Page Crawler"
  },
  "web_accessible_resources": [
    {
      "resources": ["installer.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
